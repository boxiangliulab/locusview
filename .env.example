# locusview environment configuration (example)
#
# 12-Factor principle: configuration lives in the environment, not in source code.
# Copy this file to `.env` and fill in real values. NEVER commit `.env` (it's gitignored).
#
#   cp .env.example .env
#
# Nothing here is required in Phase 0 — these are placeholders for Phase 1 onward.

# Where locusview reads its data files (Parquet + tabix). Absolute path recommended.
LOCUSVIEW_DATA_DIR=./data

# Application settings
LOCUSVIEW_ENV=development          # development | production
LOCUSVIEW_LOG_LEVEL=INFO

# Object storage for bulk downloads (Cloudflare R2, S3-compatible) — Phase 1+
# Leave blank until we wire up downloads. Do not paste real credentials into .env.example.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
