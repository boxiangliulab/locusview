# locusview environment configuration (example)
#
# 12-Factor principle: configuration lives in the environment, not in source code.
# Copy this file to `.env` and fill in real values. NEVER commit `.env` (it's gitignored).
#
#   cp .env.example .env
#
# Nothing here is required in Phase 0 — these are placeholders for Phase 1 onward.

# Where locusview reads its data files (Parquet + tabix). Absolute path recommended.
LOCUSVIEW_DATA_DIR=./data

# Application settings
LOCUSVIEW_ENV=development          # development | production
LOCUSVIEW_LOG_LEVEL=INFO

# Object storage for bulk downloads (Cloudflare R2, S3-compatible) — Phase 1+
# Leave blank until we wire up downloads. Do not paste real credentials into .env.example.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Shared locuscompare2 QTL database (MySQL 8.3.0, schema `colotool`) — Phase 1+ (ADR-0008).
# locusview reads this with a LEAST-PRIVILEGE, read-only account (never the backend's root).
# See docs/how-to/connect-to-locuscompare2-database.md and docs/reference/locuscompare2-database.md.
# Password is injected by the deployment secret store — never commit a real value.
#
# The read-only serving account is `locuscompare` (54.254.162.217:31987); its password comes from the
# secret store / local `.env`, never committed. A public demo login (`locusview_test`) is kept for
# quick exploration only. Both exclude the `user` PII table. See the how-to (§0).
LOCUSCOMPARE2_DB_HOST=54.254.162.217   # provisioned endpoint (swap for a replica/prod host if used)
LOCUSCOMPARE2_DB_PORT=31987            # Kubernetes NodePort
LOCUSCOMPARE2_DB_NAME=colotool
LOCUSCOMPARE2_DB_USER=locuscompare     # read-only serving account
LOCUSCOMPARE2_DB_PASSWORD=             # secret store / local .env — never commit a real value
LOCUSCOMPARE2_DB_SSL_MODE=REQUIRED     # require TLS for non-local connections
